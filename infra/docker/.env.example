# ── 專案 ─────────────────────────────────────────────────────────────────────
PROJECT_NAME=open-jam

# ── 資料庫 ───────────────────────────────────────────────────────────────────
DB_HOST=${PROJECT_NAME}-postgres
DB_NAME_PREFIX=open_jam
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=

# ── Email SMTP（本地開發用 mailpit，正式以 SendGrid API Key 替換）─────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE_SOCKET=Auto
SMTP_FROM=noreply@openjam.co

# ── 前端頁面 URL（compose 對外埠：creator 5173 / portal 5174 / workspace 5175）─
AUTH_PAGE_URL=http://localhost:5169/
CREATOR_PAGE_URL=http://localhost:5173
PORTAL_PAGE_URL=http://localhost:5174
WORKSPACE_URL=http://localhost:5175
# 店面子網域樣板（{storeSlug} 佔位符；本地無子網域，一律導單一 creator-web）
CREATOR_BASE_URL=${CREATOR_PAGE_URL}
APP_STOREFRONT_URL_PATTERN=${CREATOR_PAGE_URL}/
# creator-web 本機無子網域時以此 slug 決定店面（需為既有商店 slug）
STORE_SLUG=mateus-asato
GITHUB_REPO_URL=https://github.com/fee8ack21/open-jam
DOCS_URL=http://localhost:5182

# ── 後端 API URL（瀏覽器視角，對應 compose 對外埠）────────────────────────────
AUTH_API_URL=http://localhost:5169
LOG_API_URL=http://localhost:5170
STORAGE_API_URL=http://localhost:5171
STORE_API_URL=http://localhost:5172
CATALOG_API_URL=http://localhost:5176
QUOTA_API_URL=http://localhost:5177
PAYMENT_API_URL=http://localhost:5178
ORDER_API_URL=http://localhost:5179
NOTIFICATION_API_URL=http://localhost:5180
CONTENT_API_URL=http://localhost:5181

# ── 身份認證（Hydra）─────────────────────────────────────────────────────────
# AUTHORITY = token iss；各服務 Hydra__Issuer 須與其完全一致
HYDRA_PUBLIC_URL=http://localhost:4444/
AUTHORITY=${HYDRA_PUBLIC_URL}
WEB_CLIENT_ID=open-jam-web
HYDRA_SERVICE_CLIENT_ID=open-jam-service
HYDRA_SERVICE_CLIENT_SECRET=
HYDRA_PUBLIC_PORT=4444
HYDRA_ADMIN_PORT=4445
HYDRA_ADMIN_URL=http://${PROJECT_NAME}-hydra:4445
# 容器網路內可達的 OIDC discovery URL（服務抓 JWKS 用）
HYDRA_INTERNAL_URL=http://${PROJECT_NAME}-hydra:4444/.well-known/openid-configuration
HYDRA_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME_PREFIX}_hydra
HYDRA_URLS_SELF_ISSUER=${AUTHORITY}
HYDRA_URLS_LOGIN=${AUTH_PAGE_URL}login
HYDRA_URLS_CONSENT=${AUTH_PAGE_URL}consent
HYDRA_URLS_LOGOUT=${AUTH_PAGE_URL}logout
HYDRA_URLS_ERROR=${AUTH_PAGE_URL}error
HYDRA_SERVE_PUBLIC_CORS_ALLOWED_ORIGINS=*
HYDRA_SECRETS_SYSTEM=
HYDRA_OIDC_SUBJECT_IDENTIFIERS_SUPPORTED_TYPES=pairwise,public
HYDRA_OIDC_SUBJECT_IDENTIFIERS_PAIRWISE_SALT=
HYDRA_TTL_AUTH_CODE=10m
HYDRA_TTL_LOGIN_CONSENT_REQUEST=10m
HYDRA_LOG_LEAK_SENSITIVE_VALUES=false

# ── Auth ─────────────────────────────────────────────────────────────────────
AUTH__CONNECTION_STRING=Host=${DB_HOST};Port=${DB_PORT};Database=${DB_NAME_PREFIX}_auth;Username=${DB_USER};Password=${DB_PASSWORD}

# ── Stripe（test mode；正式以 Secret Manager 覆蓋）────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_PLATFORM_FEE_PERCENT=10
STRIPE_PLATFORM_FEE_FIXED=1200
# 結帳成功 / 取消導回 creator-web；Connect onboarding 導回 workspace-web
PAYMENT_SUCCESS_URL=${CREATOR_PAGE_URL}/checkout/success?session_id={CHECKOUT_SESSION_ID}
PAYMENT_CANCEL_URL=${CREATOR_PAGE_URL}/checkout/cancel
PAYMENT_CONNECT_REFRESH_URL=${WORKSPACE_URL}/payouts?refresh=1
PAYMENT_CONNECT_RETURN_URL=${WORKSPACE_URL}/payouts?return=1

# ── OrderService（訂單完成信下載頁連結，佔位符 {storeSlug} / {orderId}）───────
ORDER_DOWNLOAD_URL_PATTERN=${CREATOR_PAGE_URL}/orders/{orderId}

# ── NotificationService（通知信商品連結，佔位符 {storeSlug} / {catalogId}）────
NOTIFICATION_CATALOG_URL_PATTERN=${CREATOR_PAGE_URL}/product/{catalogId}

# ── StorageService（地端 Local；正式改 Provider=Gcs 並填雙 bucket）────────────
STORAGE_PROVIDER=Local
STORAGE_PUBLIC_BUCKET=
STORAGE_PRIVATE_BUCKET=
# 公開物件匿名讀取前綴（含公開 bucket 對應段 /public）
STORAGE_PUBLIC_BASE_URL=http://localhost:5171/v1/files/blob/public
STORAGE_LOCAL_ROOT_PATH=Files
STORAGE_LOCAL_BASE_URL=http://localhost:5171
STORAGE_LOCAL_SIGNING_KEY=

# ── Bootstrap seed（跑 seed：docker compose --profile seed up bootstrap）──────
ADMIN_EMAIL=
ADMIN_PASSWORD=
MOCK_USERS_ENABLED=false
MOCK_STORES_ENABLED=false
