# 專案
PROJECT_NAME=open-jam

# 部署路徑
EXTERNAL_URL=http://localhost/

# 資料庫
DB_HOST=${PROJECT_NAME}-postgres
DB_NAME_PREFIX=open_jam
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=

# Redis
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_VIRTUAL_HOST=${PROJECT_NAME}
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=

# email smtp（本地開發預設 mailpit：SMTP_HOST=mailpit, PORT=1025, SSL=false）
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_ENABLE_SSL=false
SMTP_FROM=noreply@openjam.co

# 身份認證
HYDRA_PUBLIC_URL=http://localhost:4444/
AUTHORITY=${HYDRA_PUBLIC_URL}
AUTH_PAGE_URL=${EXTERNAL_URL}auth/
WORKSPACE_URL=${EXTERNAL_URL}workspace/
WEB_CLIENT_ID=open-jam-web
SERVICE_AUTHORITY=${HYDRA_PUBLIC_URL}
SERVICE_CLIENT_ID=open-jam-service
SERVICE_CLIENT_SECRET=

# Hydra
HYDRA_PUBLIC_PORT=4444
HYDRA_ADMIN_PORT=4445
HYDRA_ADMIN_URL=http://${PROJECT_NAME}-hydra:4445
HYDRA_DSN=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME_PREFIX}_hydra
HYDRA_URLS_SELF_ISSUER=${HYDRA_PUBLIC_URL}
HYDRA_URLS_LOGIN=${AUTH_PAGE_URL}login
HYDRA_URLS_CONSENT=${AUTH_PAGE_URL}consent
HYDRA_URLS_LOGOUT=${AUTH_PAGE_URL}logout
HYDRA_SERVE_PUBLIC_CORS_ALLOWED_ORIGINS=*
HYDRA_SECRETS_SYSTEM=
HYDRA_OIDC_SUBJECT_IDENTIFIERS_SUPPORTED_TYPES=pairwise,public
HYDRA_OIDC_SUBJECT_IDENTIFIERS_PAIRWISE_SALT=
HYDRA_TTL_AUTH_CODE=10m
HYDRA_TTL_LOGIN_CONSENT_REQUEST=10m
HYDRA_LOG_LEAK_SENSITIVE_VALUES=false

AUTH__INTERNAL_URL=http://${PROJECT_NAME}-auth:8080/
AUTH__EXTERNAL_URL=${EXTERNAL_URL}auth/
AUTH__CONNECTION_STRING=Host=${DB_HOST}:${DB_PORT};Database=${DB_NAME_PREFIX}_auth;Username=${DB_USER};Password=${DB_PASSWORD}

# MinIO（物件儲存，本地開發）
MINIO_HOST=${PROJECT_NAME}-minio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=
MINIO_BUCKET=open-jam
