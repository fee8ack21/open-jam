  "components": {
    "schemas": {
      "CreateFaqItemRequest": {
        "type": "object",
        "properties": {
          "category": {
            "$ref": "#/components/schemas/FaqCategory"
          },
          "question": {
            "type": "string",
            "description": "問題。",
            "nullable": true,
            "example": "Open Jam 是什麼？"
          },
          "answer": {
            "type": "string",
            "description": "解答。",
            "nullable": true,
            "example": "Open Jam 是台灣的數位商品平台。"
          },
          "sortOrder": {
            "type": "integer",
            "description": "同分類內的顯示排序（升冪）。",
            "format": "int32",
            "example": 0
          },
          "isPublished": {
            "type": "boolean",
            "description": "是否已發布（對外公開）；預設為 true。",
            "example": true
          }
        },
        "additionalProperties": false,
        "description": "建立常見問題項目請求。"
      },
      "CreateLegalDocumentRequest": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/LegalDocumentType"
          },
          "title": {
            "type": "string",
            "description": "文件標題。",
            "nullable": true,
            "example": "服務條款"
          },
          "content": {
            "type": "string",
            "description": "文件內容（純文字；「## 」開頭為章節標題、「- 」開頭為列點）。",
            "nullable": true,
            "example": "## 歡迎加入 Open Jam"
          }
        },
        "additionalProperties": false,
        "description": "建立法律文件草稿請求；版本序號由伺服器依同類型現有最大版本 +1 產生。"
      },
      "FaqCategory": {
        "enum": [
          "Platform",
          "Buying",
          "Selling",
          "Payments"
        ],
        "type": "string",
        "description": "常見問題主題分類（對應 portal-web FAQ 頁的主題分頁）。"
      },
      "FaqItemDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "項目唯一識別碼。",
            "format": "uuid",
            "example": "3fa85f64-5717-4562-b3fc-2c963f66afa6"
          },
          "category": {
            "$ref": "#/components/schemas/FaqCategory"
          },
          "question": {
            "type": "string",
            "description": "問題。",
            "nullable": true,
            "example": "Open Jam 是什麼？"
          },
          "answer": {
            "type": "string",
            "description": "解答。",
            "nullable": true,
            "example": "Open Jam 是台灣的數位商品平台。"
          },
          "sortOrder": {
            "type": "integer",
            "description": "同分類內的顯示排序（升冪）。",
            "format": "int32",
            "example": 0
          },
          "isPublished": {
            "type": "boolean",
            "description": "是否已發布（對外公開）。",
            "example": true
          },
          "createdAt": {
            "type": "string",
            "description": "建立時間（UTC）。",
            "format": "date-time",
