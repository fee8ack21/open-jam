    "/v1/faqs": {
      "get": {
        "tags": [
          "Faqs"
        ],
        "summary": "查詢常見問題（分頁，支援分類 / 發布狀態篩選）。",
        "operationId": "List",
        "parameters": [
          {
            "name": "Offset",
            "in": "query",
            "description": "略過筆數。",
            "schema": {
              "type": "integer",
              "format": "int32",
              "example": 0
            },
            "example": 0
          },
          {
            "name": "Limit",
            "in": "query",
            "description": "每頁筆數（最大 100）。",
            "schema": {
              "type": "integer",
              "format": "int32",
              "example": 20
            },
            "example": 20
          },
          {
            "name": "Category",
            "in": "query",
            "description": "過濾主題分類；null 表示不限。",
            "schema": {
              "$ref": "#/components/schemas/FaqCategory"
            },
            "example": "Platform"
          },
          {
            "name": "IsPublished",
            "in": "query",
            "description": "過濾發布狀態；null 表示不限。",
            "schema": {
              "type": "boolean",
              "example": true
            },
            "example": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ListFaqItemsResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListFaqItemsResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListFaqItemsResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Faqs"
        ],
        "summary": "建立常見問題項目。",
        "operationId": "Create",
        "requestBody": {
          "description": "分類、問題、解答、排序與發布狀態。",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateFaqItemRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateFaqItemRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateFaqItemRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/FaqItemDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FaqItemDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/FaqItemDto"
                }
              }
            }
          }
        }
      }
    },
    "/v1/faqs/published": {
      "get": {
        "tags": [
