{
  "openapi": "3.0.1",
  "info": {
    "title": "CatalogService",
    "version": "v1"
  },
  "paths": {
    "/v1/catalog-categories": {
      "get": {
        "tags": ["CatalogCategories"],
        "summary": "列出所有分類（公開）。",
        "operationId": "List",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CatalogCategoryDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["CatalogCategories"],
        "summary": "建立分類。僅 Admin 可操作。",
        "operationId": "Create",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCatalogCategoryRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogCategoryDto"
                }
              }
            }
          }
        },
        "security": [{ "Bearer": [] }]
      }
    },
    "/v1/catalog-categories/{id}": {
      "get": {
        "tags": ["CatalogCategories"],
        "summary": "查詢單一分類（公開）。",
        "operationId": "Get",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogCategoryDto"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["CatalogCategories"],
        "summary": "更新分類。僅 Admin 可操作。",
        "operationId": "Update",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateCatalogCategoryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogCategoryDto"
                }
              }
            }
          }
        },
        "security": [{ "Bearer": [] }]
      },
      "delete": {
        "tags": ["CatalogCategories"],
        "summary": "刪除分類（不可有子分類或被商品引用）。僅 Admin 可操作。",
        "operationId": "Delete",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          }
        },
        "security": [{ "Bearer": [] }]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "CatalogCategoryDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "parentId": { "type": "string", "format": "uuid", "nullable": true },
          "name": { "type": "string", "nullable": true },
          "slug": { "type": "string", "nullable": true },
          "sortOrder": { "type": "integer", "format": "int32" }
        },
        "additionalProperties": false
      },
      "CreateCatalogCategoryRequest": {
        "type": "object",
        "properties": {
          "parentId": { "type": "string", "format": "uuid", "nullable": true },
          "name": { "type": "string", "nullable": true },
          "slug": { "type": "string", "nullable": true },
          "sortOrder": { "type": "integer", "format": "int32" }
        },
        "additionalProperties": false
      },
      "UpdateCatalogCategoryRequest": {
        "type": "object",
        "properties": {
          "parentId": { "type": "string", "format": "uuid", "nullable": true },
          "name": { "type": "string", "nullable": true },
          "slug": { "type": "string", "nullable": true },
          "sortOrder": { "type": "integer", "format": "int32", "nullable": true }
        },
        "additionalProperties": false
      }
    }
  }
}
