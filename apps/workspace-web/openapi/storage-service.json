                        "description": "\u7269\u4ef6\u9375\u503c\uff08catch-all \u8def\u5f91\uff09\u3002",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "expires",
                        "in": "query",
                        "description": "URL \u5230\u671f\u6642\u9593\uff08Unix \u79d2\uff09\u3002",
