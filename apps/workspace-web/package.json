{
  "name": "workspace-web",
  "version": "0.0.7",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.7.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "gen:api": "swagger-typescript-api generate -p http://localhost:5172/swagger/v1/swagger.json -o src/services/api -n store-service.ts --single-http-client"
  },
  "dependencies": {
    "naive-ui": "^2.40.1",
    "oidc-client-ts": "^3.5.0",
    "pinia": "^2.2.2",
    "vue": "^3.4.38",
    "vue-router": "^4.4.3"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-vue": "^5.1.2",
    "@vue/tsconfig": "^0.5.1",
    "swagger-typescript-api": "^13.12.2",
    "typescript": "~5.5.4",
    "vite": "^5.4.2",
    "vue-tsc": "^2.0.29"
  }
}
