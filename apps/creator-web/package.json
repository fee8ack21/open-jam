{
  "name": "creator-web",
  "version": "0.0.21",
  "private": true,
  "type": "module",
  "description": "Open Jam — 創作者數位市集 (Vue 3 + Vite + Pinia + Vue Router)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "gen:api": "pnpm gen:api:store && pnpm gen:api:catalog && pnpm gen:api:order",
    "gen:api:store": "swagger-typescript-api generate -p openapi/store-service.json -o src/api -n store-service.ts --single-http-client --module-name-first-tag",
    "gen:api:catalog": "swagger-typescript-api generate -p openapi/catalog-service.json -o src/api -n catalog-service.ts --single-http-client --module-name-first-tag",
    "gen:api:order": "swagger-typescript-api generate -p openapi/order-service.json -o src/api -n order-service.ts --single-http-client --module-name-first-tag",
    "gen:i18n": "node scripts/i18n-xlsx-to-json.mjs",
    "gen:i18n:xlsx": "node scripts/i18n-json-to-xlsx.mjs"
  },
  "dependencies": {
    "naive-ui": "^2.40.1",
    "oidc-client-ts": "^3.5.0",
    "pinia": "^2.2.4",
    "vue": "^3.5.12",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^9.30.0",
    "exceljs": "^4.4.0",
    "prettier": "^3.3.3",
    "swagger-typescript-api": "^13.12.2",
    "typescript": "~5.5.4",
    "vite": "^5.4.9",
    "vue-tsc": "^2.1.0"
  }
}
