@model PasswordFieldModel
@{
    var shellClass = "input-shell" + (Model.Error != null ? " err" : "");
    var inputType = Model.Show ? "text" : "password";
    var toggleIcon = Model.Show ? "eyeOff" : "eye";
    var toggleTitle = Model.Show ? "隱藏密碼" : "顯示密碼";
}

<div class="field" data-field="@Model.Id" data-strength="@(Model.ShowStrength ? "1" : null)">
    <label class="field-label">
        <span>@Model.Label</span>
        @if (Model.LabelRight != null)
        {
            @Model.LabelRight
        }
    </label>
    <div class="@shellClass">
        <span class="lead">@IconHelper.Render("lock", 18)</span>
        <input type="@inputType" data-input="@Model.Id" data-pw="1"
               value="@(Model.Value ?? "")" placeholder="@(Model.Placeholder ?? "")"
               autocomplete="@(Model.AutoComplete ?? "off")">
        <button type="button" class="pw-toggle" data-pwtoggle="@Model.Id" title="@toggleTitle">
            @IconHelper.Render(toggleIcon, 18)
        </button>
    </div>
    @if (Model.Error != null)
    {
        <span class="field-err">@IconHelper.Render("alert", 13) @Model.Error</span>
    }
</div>
