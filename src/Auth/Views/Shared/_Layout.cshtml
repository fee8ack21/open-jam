<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script>
    // 僅 iOS 加上 maximum-scale=1：關閉聚焦 input 時的自動放大（頁面放大後不會自行復原）。
    // iOS 10+ 的手動雙指縮放不受 maximum-scale 限制，無障礙不受影響；Android 不套用以免鎖縮放。
    if (/iPhone|iPad|iPod/.test(navigator.userAgent)) {
        document.querySelector('meta[name=viewport]')
            .setAttribute('content', 'width=device-width, initial-scale=1.0, maximum-scale=1.0');
    }
    </script>
    <title>@ViewData["Title"]</title>
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml">
    <link rel="icon" href="~/favicon-32.png" type="image/png" sizes="32x32">
    <link rel="icon" href="~/favicon.ico" sizes="any">
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png">
    <link rel="stylesheet" href="~/css/site.css">
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
</head>
<body>
    <div class="auth-viewport">
        @RenderBody()
        <form class="lang-switch" action="/set-language" method="get">
            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString">
            <button type="button" class="lang-trigger" data-langtoggle>
                @IconHelper.Render("globe", 15) <span class="lang-label">@(System.Globalization.CultureInfo.CurrentUICulture.Name switch { "en" => "English", _ => "繁體中文" })</span>
                @IconHelper.Render("chevronDown", 10)
            </button>
            <div class="lang-menu" data-langmenu>
                <button type="submit" name="culture" value="zh-Hant" class="lang-opt @(System.Globalization.CultureInfo.CurrentUICulture.Name == "zh-Hant" ? "on" : "")">
                    <span class="lang-opt-check">@IconHelper.Render("check", 14)</span>
                    <span>繁體中文</span>
                </button>
                <button type="submit" name="culture" value="en" class="lang-opt @(System.Globalization.CultureInfo.CurrentUICulture.Name == "en" ? "on" : "")">
                    <span class="lang-opt-check">@IconHelper.Render("check", 14)</span>
                    <span>English</span>
                </button>
            </div>
        </form>
    </div>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/validation-setup.js"></script>
    <script src="~/js/form-ui.js"></script>
    <script>
    $(function(){
        var $menu = $('[data-langmenu]');
        $('[data-langtoggle]').on('click', function(e){
            e.stopPropagation();
            $menu.toggleClass('open');
        });
        $(document).on('click', function(){ $menu.removeClass('open'); });
        $menu.on('click', 'button', function(){ $menu.removeClass('open'); });
    });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
