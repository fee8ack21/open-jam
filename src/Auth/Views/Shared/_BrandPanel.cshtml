@model BrandPanelViewModel

<aside class="brand-panel">
    <div class="collage" aria-hidden="true">
        <div class="fc" style="top:9%;right:20%;--rot:5deg;--depth:7px;">
            <div class="fc-tape" style="background:rgba(255,222,0,.85);--tr:-4deg"></div>
            <span class="fc-cat" style="background:#FF6B35;color:#fff">PHOTO</span>
            <div class="fc-thumb" style="background:#FF6B35">@IconHelper.Render("image", 28)</div>
            <div class="fc-title">霓虹城市夜景</div>
            <div class="fc-foot">
                <span class="fc-price">$24</span>
                <span class="fc-star">@IconHelper.Render("star", 11) 4.9</span>
            </div>
        </div>
        <div class="fc" style="top:37%;right:3%;--rot:-4deg;--depth:5px;">
            <div class="fc-tape" style="background:rgba(125,217,255,.85);--tr:3deg"></div>
            <span class="fc-cat" style="background:var(--c-cyan)">SCORE</span>
            <div class="fc-thumb" style="background:var(--c-cyan)">@IconHelper.Render("beats", 26)</div>
            <div class="fc-title">Lo-Fi 節拍包</div>
            <div class="fc-foot">
                <span class="fc-price">$18</span>
                <span class="fc-star">@IconHelper.Render("star", 11) 4.8</span>
            </div>
        </div>
        <div class="fc" style="bottom:9%;right:4%;--rot:3deg;--depth:8px;">
            <div class="fc-tape" style="background:rgba(184,255,159,.85);--tr:-3deg"></div>
            <span class="fc-cat" style="background:#FFB020">EBOOK</span>
            <div class="fc-thumb fc-thumb-text" style="background:#FFB020">Aa</div>
            <div class="fc-title">插畫家手冊</div>
            <div class="fc-foot">
                <span class="fc-free">@T["Brand.Free"]</span>
                <span class="fc-star">@IconHelper.Render("star", 11) 5.0</span>
            </div>
        </div>
        <div class="shape dot" style="top:17%;left:8%;width:42px;height:42px;background:var(--c-yellow);--depth:7px;"></div>
        <div class="shape sq" style="bottom:12%;left:6%;width:38px;height:38px;background:var(--c-lime);--rot:14deg;--depth:11px;"></div>
        <div class="shape glyph" style="top:13%;left:32%;--rot:-8deg;--depth:12px;">@IconHelper.Render("note", 28)</div>
    </div>
    <div class="brand-content">
        @await Html.PartialAsync("_BrandLockup")
        <div class="brand-mid">
            <span class="brand-eyebrow">@IconHelper.Render("note", 12) @T["Brand.Eyebrow"]</span>
            <h1 class="brand-headline">@Html.Raw(Model.Headline)</h1>
            <p class="brand-sub">@Model.Sub</p>
        </div>
        <div class="brand-foot">
            <span>@T["Brand.FooterCreators"]</span>
            <span class="foot-divider" style="background:var(--c-yellow)"></span>
            <span>@T["Brand.FooterWorks"]</span>
            <span class="foot-divider" style="background:var(--c-pink)"></span>
            <span>@T["Brand.FooterPayments"]</span>
        </div>
    </div>
</aside>
