@model List<Auth.Models.LegalDocumentDto>
@using Auth.Data.Entities
@{
    // 條款內容來自資料庫的啟用中版本（LegalDocument），由後台編輯；
    // key 供 form-ui.js 追蹤「已點閱」狀態（data-legal-open / data-tick 對應）。
    static (string Key, string Icon) MetaOf(LegalDocumentType type) =>
        type == LegalDocumentType.TermsOfService ? ("terms", "note") : ("privacy", "shield");
}
<div id="legal-scrim" class="modal-scrim" style="display:none" data-legal-scrim>

    @foreach (var doc in Model)
    {
        var (key, icon) = MetaOf(doc.Type);
        <div class="modal-card" role="dialog" aria-modal="true" aria-label="@doc.Title" style="display:none" data-legal-card="@key">
            <div class="modal-head">
                <div class="modal-badge @key">@IconHelper.Render(icon, 22)</div>
                <h3 class="modal-title">@doc.Title</h3>
                <p class="modal-meta">Open Jam · v@(doc.Version) · @T["LegalTerms.LastUpdated"] @((doc.ActivatedAt ?? doc.CreatedAt).ToString("yyyy-MM-dd"))</p>
                <button class="modal-x" data-legal-close aria-label="@T["LegalTerms.CloseAria"]">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"></path></svg>
                </button>
            </div>
            <div class="modal-body">
                @LegalContentHelper.Render(doc.Content)
            </div>
            <div class="modal-foot">
                <button class="btn-ghost" data-legal-close>@T["LegalTerms.Close"]</button>
                <button class="btn-pop violet" data-legal-ack>@IconHelper.Render("check", 17, 2.4) @T["LegalTerms.Acknowledge"]</button>
            </div>
        </div>
    }

</div>
