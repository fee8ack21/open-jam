@{
    ViewData["Title"] = "Open Jam · 忘記密碼";
}

<div class="auth-shell font-bricolage" id="auth-shell" data-screen="forgot">
    @await Html.PartialAsync("_BrandPanel", new BrandPanelModel {
        Headline = "別擔心，<br/>我們<span class=\"hl hl-cyan\">幫你</span>。",
        Sub = "輸入註冊信箱，我們會立刻把重置連結寄給你。"
    })
    <main class="form-panel">
        <div class="mobile-brand">
            <span class="brand-mark" style="background:linear-gradient(135deg,var(--c-violet),var(--c-pink))">
                <span style="color:#fff;display:grid;place-items:center">@IconHelper.BrandMark(18)</span>
            </span>
            <span class="brand-name">Open Jam</span>
        </div>
        <div class="form-wrap">
            <div class="screen">
                <a class="back-link" asp-action="Login">@IconHelper.Render("arrowLeft", 16) 返回登入</a>
                <p class="form-eyebrow">@IconHelper.Render("key", 13) 帳號救援</p>
                <h2 class="form-title">忘記密碼？</h2>
                <p class="form-sub">輸入你的註冊信箱，我們會寄一條重置連結給你。連結 30 分鐘內有效。</p>
                <div class="form-body">
                    @await Html.PartialAsync("_Field", new FieldModel {
                        Id = "email", Label = "電子信箱", Type = "email", Icon = "mail",
                        Placeholder = "you@example.com", AutoComplete = "email"
                    })
                    <button class="btn-pop violet" data-submit>
                        @IconHelper.Render("send", 17) 寄送重置連結
                    </button>
                </div>
                <p class="form-foot">想起來了？<a asp-action="Login" class="link-strong">直接登入</a></p>
            </div>
        </div>
    </main>
    @await Html.PartialAsync("_TweaksPanel")
    <style id="accent-style"></style>
</div>
