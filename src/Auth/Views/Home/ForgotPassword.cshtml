@model ForgotPasswordViewModel
@{
    ViewData["Title"] = T["Forgot.PageTitle"];
}

<div class="auth-shell" data-screen="forgot">
    @await Html.PartialAsync("_BrandPanel", new BrandPanelViewModel {
        Headline = T["Forgot.BrandHeadline"].Value,
        Sub = T["Forgot.BrandSub"].Value
    })
    <main class="form-panel">
        <div class="mobile-brand">
            @await Html.PartialAsync("_BrandLockup")
        </div>
        <div class="form-wrap">
            <div class="screen">
<p class="form-eyebrow">@IconHelper.Render("key", 13) @T["Forgot.Eyebrow"]</p>
                <h2 class="form-title">@T["Forgot.Title"]</h2>
                <p class="form-sub">@T["Forgot.Sub"]</p>
                <form asp-action="ForgotPassword" method="post" novalidate>
                    <input type="hidden" asp-for="LoginChallenge">
                    <div class="form-body">

                        <div class="field" data-field="Email">
                            <label class="field-label" asp-for="Email">@T["Forgot.EmailLabel"]</label>
                            <div class="input-shell @(ViewData.ModelState["Email"]?.Errors.Any() == true ? "err" : "")">
                                <span class="lead">@IconHelper.Render("mail", 18)</span>
                                <input asp-for="Email" data-input="Email"
                                       placeholder="you@example.com" autocomplete="email">
                            </div>
                            <span asp-validation-for="Email" class="field-err"></span>
                        </div>

                        <button type="submit" class="btn-pop violet">
                            @IconHelper.Render("send", 17) @T["Forgot.Submit"]
                        </button>
                    </div>
                </form>
                <p class="form-foot">@T["Forgot.Remembered"] <a asp-action="Login" asp-route-login_challenge="@Model.LoginChallenge" class="link-strong">@T["Forgot.Login"]</a></p>
            </div>
        </div>
    </main>
</div>
