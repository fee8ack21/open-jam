@model ResetPasswordViewModel
@{
    ViewData["Title"] = T["Reset.PageTitle"];
}

<div class="auth-shell" data-screen="reset">
    @await Html.PartialAsync("_BrandPanel", new BrandPanelViewModel {
        Headline = T["Reset.BrandHeadline"].Value,
        Sub = T["Reset.BrandSub"].Value
    })
    <main class="form-panel">
        <div class="mobile-brand">
            <span class="brand-mark" style="background:linear-gradient(135deg,var(--c-violet),var(--c-pink))">
                <span style="color:#fff;display:grid;place-items:center">@IconHelper.BrandMark(18)</span>
            </span>
            <span class="brand-name">Open Jam</span>
        </div>
        <div class="form-wrap">
            <div class="screen">
                <p class="form-eyebrow">@IconHelper.Render("key", 13) @T["Reset.Eyebrow"]</p>
                <h2 class="form-title">@T["Reset.Title"]</h2>
                <p class="form-sub">@T["Reset.Sub"]</p>
                <form asp-action="ResetPassword" method="post" novalidate>
                    <input type="hidden" asp-for="Token">
                    <div class="form-body">
                        @if (ViewData.ModelState[""] is { } ms && ms.Errors.Any())
                        {
                            <p class="field-err" style="display:block">@ms.Errors[0].ErrorMessage</p>
                        }

                        <div class="field" data-field="Password" data-strength="1">
                            <label class="field-label" asp-for="Password">@T["Reset.NewPasswordLabel"]</label>
                            <div class="input-shell @(ViewData.ModelState["Password"]?.Errors.Any() == true ? "err" : "")">
                                <span class="lead">@IconHelper.Render("lock", 18)</span>
                                <input asp-for="Password" type="password" data-input="Password" data-pw="1"
                                       data-val-minpasswordstrength="@T["Register.PasswordStrength"]"
                                       placeholder="@T["Reset.NewPasswordPlaceholder"]" autocomplete="new-password">
                                <button type="button" class="pw-toggle" data-pwtoggle="Password" title="@T["Login.ShowPassword"]">
                                    @IconHelper.Render("eye", 18)
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="field-err"></span>
                        </div>

                        <div class="field" data-field="ConfirmPassword">
                            <label class="field-label" asp-for="ConfirmPassword">@T["Reset.ConfirmPasswordLabel"]</label>
                            <div class="input-shell @(ViewData.ModelState["ConfirmPassword"]?.Errors.Any() == true ? "err" : "")">
                                <span class="lead">@IconHelper.Render("lock", 18)</span>
                                <input asp-for="ConfirmPassword" type="password" data-input="ConfirmPassword" data-pw="1"
                                       placeholder="@T["Reset.ConfirmPasswordPlaceholder"]" autocomplete="new-password">
                                <button type="button" class="pw-toggle" data-pwtoggle="ConfirmPassword" title="@T["Login.ShowPassword"]">
                                    @IconHelper.Render("eye", 18)
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="field-err"></span>
                        </div>

                        <button type="submit" class="btn-pop violet">
                            @IconHelper.Render("check", 18, 2.4) @T["Reset.Submit"]
                        </button>
                    </div>
                </form>
                <p class="form-foot"><a asp-action="Login" class="link-strong">@T["Reset.Cancel"]</a></p>
            </div>
        </div>
    </main>
</div>
