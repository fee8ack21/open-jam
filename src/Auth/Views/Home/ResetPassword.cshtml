@{
    ViewData["Title"] = "Open Jam · 重置密碼";
}

<div class="auth-shell font-bricolage" id="auth-shell" data-screen="reset">
    @await Html.PartialAsync("_BrandPanel", new BrandPanelModel {
        Headline = "設定一組<br/><span class=\"hl hl-lime\">新密碼</span>。",
        Sub = "選一組夠強的密碼，好好保護你的創作資產。"
    })
    <main class="form-panel">
        <div class="mobile-brand">
            <span class="brand-mark" style="background:linear-gradient(135deg,var(--c-violet),var(--c-pink))">
                <span style="color:#fff;display:grid;place-items:center">@IconHelper.BrandMark(18)</span>
            </span>
            <span class="brand-name">Open Jam</span>
        </div>
        <div class="form-wrap">
            <div class="screen">
                <p class="form-eyebrow">@IconHelper.Render("key", 13) 設定新密碼</p>
                <h2 class="form-title">重置密碼</h2>
                <p class="form-sub">為你的 Open Jam 帳號設定一組全新密碼。設定後其他裝置會自動登出。</p>
                <div class="form-body">
                    @await Html.PartialAsync("_PasswordField", new PasswordFieldModel {
                        Id = "pw", Label = "新密碼", Placeholder = "輸入新密碼",
                        ShowStrength = true, AutoComplete = "new-password"
                    })
                    @await Html.PartialAsync("_PasswordField", new PasswordFieldModel {
                        Id = "pw2", Label = "確認新密碼", Placeholder = "再次輸入新密碼",
                        AutoComplete = "new-password"
                    })
                    <button class="btn-pop violet" data-submit>
                        @IconHelper.Render("check", 18, 2.4) 更新密碼
                    </button>
                </div>
                <p class="form-foot"><a asp-action="Login" class="link-strong">取消，返回登入</a></p>
            </div>
        </div>
    </main>
    @await Html.PartialAsync("_TweaksPanel")
    <style id="accent-style"></style>
</div>
