@{
    ViewData["Title"] = T["ForgotSent.PageTitle"];
    var email = ViewBag.Email as string ?? "";
}

<div class="auth-shell" data-screen="forgot-sent">
    @await Html.PartialAsync("_BrandPanel", new BrandPanelViewModel {
        Headline = T["Forgot.BrandHeadline"].Value,
        Sub = T["Forgot.BrandSub"].Value
    })
    <main class="form-panel">
        <div class="mobile-brand">
            @await Html.PartialAsync("_BrandLockup")
        </div>
        <div class="form-wrap">
            <div class="screen">
                <div class="success-ring violet">@IconHelper.Render("mail", 40)</div>
                <h2 class="form-title">@T["ForgotSent.Title"]</h2>
                <p class="form-sub">@T["ForgotSent.Sub"]</p>
                <div class="email-chip">@IconHelper.Render("mail", 16) @email</div>
                <p class="form-sub" style="margin-top:18px">@T["ForgotSent.Instruction"]</p>
                <div class="form-body">
                    <a class="btn-pop violet" asp-action="Login">
                        @IconHelper.Render("arrowRight", 17) @T["ForgotSent.Back"]
                    </a>
                </div>
                <p class="resend" style="text-align:center" data-resend-screen="forgot-sent" data-resend-email="@email">
                    @T["ForgotSent.NotReceived"] <span class="resend-slot"></span>
                </p>
            </div>
        </div>
    </main>
</div>
