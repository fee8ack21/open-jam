@{
    ViewData["Title"] = "Open Jam · 建立帳號";
    var agreeLabel =
        "我已閱讀並同意 " +
        "<button type=\"button\" class=\"legal-link\" data-legal-open=\"terms\">服務條款<span class=\"read-tick\" data-tick=\"terms\"></span></button>" +
        " 與 " +
        "<button type=\"button\" class=\"legal-link\" data-legal-open=\"privacy\">隱私政策<span class=\"read-tick\" data-tick=\"privacy\"></span></button>";
}

<div class="auth-shell font-bricolage" id="auth-shell" data-screen="register">
    @await Html.PartialAsync("_BrandPanel", new BrandPanelModel {
        Headline = "把作品<br/>變成 <span class=\"hl hl-yellow\">收入</span>。",
        Sub = "加入 12,400+ 創作者，今天就開始在 Open Jam 上架你的數位作品。"
    })
    <main class="form-panel">
        <div class="mobile-brand">
            <span class="brand-mark" style="background:linear-gradient(135deg,var(--c-violet),var(--c-pink))">
                <span style="color:#fff;display:grid;place-items:center">@IconHelper.BrandMark(18)</span>
            </span>
            <span class="brand-name">Open Jam</span>
        </div>
        <div class="form-wrap">
            <div class="screen">
                <p class="form-eyebrow">@IconHelper.Render("sparkle", 13) 開始創作</p>
                <h2 class="form-title">建立帳號</h2>
                <p class="form-sub">免費開店、零月費，售出才收 3% 手續費。30 秒就能上手。</p>
                <div class="form-body">
                    @await Html.PartialAsync("_Field", new FieldModel {
                        Id = "name", Label = "創作者暱稱", Icon = "user",
                        Placeholder = "例如：小雨工作室", AutoComplete = "nickname"
                    })
                    @await Html.PartialAsync("_Field", new FieldModel {
                        Id = "email", Label = "電子信箱", Type = "email", Icon = "mail",
                        Placeholder = "you@example.com", AutoComplete = "email"
                    })
                    @await Html.PartialAsync("_PasswordField", new PasswordFieldModel {
                        Id = "pw", Label = "密碼", Placeholder = "設定一組密碼",
                        ShowStrength = true, AutoComplete = "new-password"
                    })
                    <div class="field" data-field="agree" style="margin-top:-2px">
                        @await Html.PartialAsync("_Checkbox", new CheckboxModel {
                            Id = "agree", Label = agreeLabel
                        })
                    </div>
                    <button class="btn-pop" data-submit>
                        @IconHelper.Render("sparkle", 18) 建立帳號
                    </button>
                </div>
                <p class="form-foot">已經有帳號了？<a asp-action="Login" class="link-strong">前往登入</a></p>
            </div>
        </div>
    </main>
    @await Html.PartialAsync("_TweaksPanel")
    @await Html.PartialAsync("_LegalModal")
    <style id="accent-style"></style>
</div>
