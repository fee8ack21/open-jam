@model RegisterViewModel
@{
    ViewData["Title"] = "Open Jam · 建立帳號";
    var agreeLabel =
        "我已閱讀並同意 " +
        "<button type=\"button\" class=\"legal-link\" data-legal-open=\"terms\">服務條款<span class=\"read-tick\" data-tick=\"terms\"></span></button>" +
        " 與 " +
        "<button type=\"button\" class=\"legal-link\" data-legal-open=\"privacy\">隱私政策<span class=\"read-tick\" data-tick=\"privacy\"></span></button>";
}

<div class="auth-shell font-bricolage" id="auth-shell" data-screen="register">
    @await Html.PartialAsync("_BrandPanel", new BrandPanelModel {
        Headline = "把作品<br/>變成 <span class=\"hl hl-yellow\">收入</span>。",
        Sub = "加入 12,400+ 創作者，今天就開始在 Open Jam 上架你的數位作品。"
    })
    <main class="form-panel">
        <div class="mobile-brand">
            <span class="brand-mark" style="background:linear-gradient(135deg,var(--c-violet),var(--c-pink))">
                <span style="color:#fff;display:grid;place-items:center">@IconHelper.BrandMark(18)</span>
            </span>
            <span class="brand-name">Open Jam</span>
        </div>
        <div class="form-wrap">
            <div class="screen">
                <p class="form-eyebrow">@IconHelper.Render("sparkle", 13) 開始創作</p>
                <h2 class="form-title">建立帳號</h2>
                <p class="form-sub">免費開店、零月費，售出才收 3% 手續費。30 秒就能上手。</p>
                <form asp-action="Register" method="post" novalidate>
                    <input type="hidden" asp-for="LoginChallenge">
                    <div class="form-body">

                        <div class="field" data-field="Email">
                            <label class="field-label" asp-for="Email">電子信箱</label>
                            <div class="input-shell @(ViewData.ModelState["Email"]?.Errors.Any() == true ? "err" : "")">
                                <span class="lead">@IconHelper.Render("mail", 18)</span>
                                <input asp-for="Email" data-input="Email"
                                       placeholder="you@example.com" autocomplete="email">
                            </div>
                            <span asp-validation-for="Email" class="field-err"></span>
                        </div>

                        <div class="field" data-field="Password" data-strength="1">
                            <label class="field-label" asp-for="Password">密碼</label>
                            <div class="input-shell @(ViewData.ModelState["Password"]?.Errors.Any() == true ? "err" : "")">
                                <span class="lead">@IconHelper.Render("lock", 18)</span>
                                <input asp-for="Password" type="password" data-input="Password" data-pw="1"
                                       data-val-minpasswordstrength="密碼需含大小寫英文、數字及特殊符號（8–20 字元）"
                                       placeholder="設定一組密碼" autocomplete="new-password">
                                <button type="button" class="pw-toggle" data-pwtoggle="Password" title="顯示密碼">
                                    @IconHelper.Render("eye", 18)
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="field-err"></span>
                        </div>

                        <div class="field" data-field="ConfirmPassword">
                            <label class="field-label" asp-for="ConfirmPassword">確認密碼</label>
                            <div class="input-shell @(ViewData.ModelState["ConfirmPassword"]?.Errors.Any() == true ? "err" : "")">
                                <span class="lead">@IconHelper.Render("lock", 18)</span>
                                <input asp-for="ConfirmPassword" type="password" data-input="ConfirmPassword" data-pw="1"
                                       placeholder="再輸入一次密碼" autocomplete="new-password">
                                <button type="button" class="pw-toggle" data-pwtoggle="ConfirmPassword" title="顯示密碼">
                                    @IconHelper.Render("eye", 18)
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="field-err"></span>
                        </div>

                        <div class="field" data-field="Agree" style="margin-top:-2px">
                            <div class="checkbox @(Model.Agree ? "on" : "")" data-checkbox="Agree"
                                 role="checkbox" aria-checked="@(Model.Agree ? "true" : "false")" tabindex="0">
                                <span class="box">@IconHelper.Render("check", 13, 2.6)</span>
                                <span>@Html.Raw(agreeLabel)</span>
                            </div>
                            <input asp-for="Agree"
                                   style="position:absolute;width:1px;height:1px;opacity:0;pointer-events:none">
                            <span asp-validation-for="Agree" class="field-err"></span>
                        </div>

                        <button type="submit" class="btn-pop">
                            @IconHelper.Render("sparkle", 18) 建立帳號
                        </button>
                    </div>
                </form>
                <p class="form-foot">已經有帳號了？<a asp-action="Login" asp-route-login_challenge="@Model.LoginChallenge" class="link-strong">前往登入</a></p>
            </div>
        </div>
    </main>
    @await Html.PartialAsync("_TweaksPanel")
    @await Html.PartialAsync("_LegalModal")
    <style id="accent-style"></style>
</div>
