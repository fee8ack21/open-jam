@model RegisterViewModel
@{
    ViewData["Title"] = T["Register.PageTitle"];

    // 條款 / 隱私連結：僅在有啟用中版本時渲染為需點閱的 dialog 按鈕（form-ui.js 依
    // data-legal-open 追蹤點閱狀態），未 seed 文件時退化為純文字、不強制點閱。
    static string LegalLink(bool hasDocument, string key, string text) => hasDocument
        ? "<button type=\"button\" class=\"legal-link\" data-legal-open=\"" + key + "\">" + text + "<span class=\"read-tick\" data-tick=\"" + key + "\"></span></button>"
        : "<span class=\"legal-link\">" + text + "</span>";

    var agreeLabel =
        T["Register.AgreePrefix"] +
        LegalLink(Model.TermsDocument is not null, "terms", T["Register.TermsOfService"].Value) +
        T["Register.And"] +
        LegalLink(Model.PrivacyDocument is not null, "privacy", T["Register.PrivacyPolicy"].Value);

    var legalDocuments = new List<LegalDocumentDto>();
    if (Model.TermsDocument is not null) legalDocuments.Add(Model.TermsDocument);
    if (Model.PrivacyDocument is not null) legalDocuments.Add(Model.PrivacyDocument);
}

<div class="auth-shell" data-screen="register">
    @await Html.PartialAsync("_BrandPanel", new BrandPanelViewModel {
        Headline = T["Register.BrandHeadline"].Value,
        Sub = T["Register.BrandSub"].Value
    })
    <main class="form-panel">
        <div class="mobile-brand">
            <span class="brand-mark" style="background:linear-gradient(135deg,var(--c-violet),var(--c-pink))">
                <span style="color:#fff;display:grid;place-items:center">@IconHelper.BrandMark(18)</span>
            </span>
            <span class="brand-name">Open Jam</span>
        </div>
        <div class="form-wrap">
            <div class="screen">
                <p class="form-eyebrow">@IconHelper.Render("sparkle", 13) @T["Register.Eyebrow"]</p>
                <h2 class="form-title">@T["Register.Title"]</h2>
                <p class="form-sub">@T["Register.Sub"]</p>
                <form asp-action="Register" method="post" novalidate>
                    <input type="hidden" asp-for="LoginChallenge">
                    <div class="form-body">

                        <div class="field" data-field="Email">
                            <label class="field-label" asp-for="Email">@T["Register.EmailLabel"]</label>
                            <div class="input-shell @(ViewData.ModelState["Email"]?.Errors.Any() == true ? "err" : "")">
                                <span class="lead">@IconHelper.Render("mail", 18)</span>
                                <input asp-for="Email" data-input="Email"
                                       placeholder="you@example.com" autocomplete="email">
                            </div>
                            <span asp-validation-for="Email" class="field-err"></span>
                        </div>

                        <div class="field" data-field="Password" data-strength="1">
                            <label class="field-label" asp-for="Password">@T["Register.PasswordLabel"]</label>
                            <div class="input-shell @(ViewData.ModelState["Password"]?.Errors.Any() == true ? "err" : "")">
                                <span class="lead">@IconHelper.Render("lock", 18)</span>
                                <input asp-for="Password" type="password" data-input="Password" data-pw="1"
                                       data-val-minpasswordstrength="@T["Register.PasswordStrength"]"
                                       placeholder="@T["Register.PasswordPlaceholder"]" autocomplete="new-password">
                                <button type="button" class="pw-toggle" data-pwtoggle="Password" title="@T["Login.ShowPassword"]">
                                    @IconHelper.Render("eye", 18)
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="field-err"></span>
                        </div>

                        <div class="field" data-field="ConfirmPassword">
                            <label class="field-label" asp-for="ConfirmPassword">@T["Register.ConfirmPasswordLabel"]</label>
                            <div class="input-shell @(ViewData.ModelState["ConfirmPassword"]?.Errors.Any() == true ? "err" : "")">
                                <span class="lead">@IconHelper.Render("lock", 18)</span>
                                <input asp-for="ConfirmPassword" type="password" data-input="ConfirmPassword" data-pw="1"
                                       placeholder="@T["Register.ConfirmPasswordPlaceholder"]" autocomplete="new-password">
                                <button type="button" class="pw-toggle" data-pwtoggle="ConfirmPassword" title="@T["Login.ShowPassword"]">
                                    @IconHelper.Render("eye", 18)
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="field-err"></span>
                        </div>

                        <div class="field" data-field="Agree" style="margin-top:-2px">
                            <div class="checkbox @(Model.Agree ? "on" : "")" data-checkbox="Agree"
                                 role="checkbox" aria-checked="@(Model.Agree ? "true" : "false")" tabindex="0">
                                <span class="box">@IconHelper.Render("check", 13, 2.6)</span>
                                <span>@Html.Raw(agreeLabel)</span>
                            </div>
                            <input asp-for="Agree" data-requires-legal="1"
                                   style="position:absolute;width:1px;height:1px;opacity:0;pointer-events:none">
                            <span asp-validation-for="Agree" class="field-err"></span>
                            <span class="field-err" data-legal-hint style="display:none">@T["Register.MustReadLegal"]</span>
                        </div>

                        <button type="submit" class="btn-pop">
                            @IconHelper.Render("sparkle", 18) @T["Register.Submit"]
                        </button>
                    </div>
                </form>
                <p class="form-foot">@T["Register.HasAccount"] <a asp-action="Login" asp-route-login_challenge="@Model.LoginChallenge" class="link-strong">@T["Register.Login"]</a></p>
            </div>
        </div>
    </main>
    @await Html.PartialAsync("_LegalModal", legalDocuments)
</div>
