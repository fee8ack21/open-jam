@{
    ViewData["Title"] = T["Error.PageTitle"];
}

<div class="auth-shell" data-screen="login-error">
    @await Html.PartialAsync("_BrandPanel", new BrandPanelViewModel {
        Headline = T["Error.BrandHeadline"].Value,
        Sub = T["Error.BrandSub"].Value
    })
    <main class="form-panel">
        <div class="mobile-brand">
            <span class="brand-mark" style="background:linear-gradient(135deg,var(--c-violet),var(--c-pink))">
                <span style="color:#fff;display:grid;place-items:center">@IconHelper.BrandMark(18)</span>
            </span>
            <span class="brand-name">Open Jam</span>
        </div>
        <div class="form-wrap"><div class="screen"><div class="success-ring danger">@IconHelper.Render("alert", 42, 2.2)</div><h2 class="form-title">@T["Error.Title"]</h2><p class="form-sub">@T["Error.Sub"]</p><div class="callout">@IconHelper.Render("shield", 18)<span>@Html.Raw(T["Error.Callout"])</span></div><div class="form-body"><a class="btn-pop violet" asp-action="Login" asp-controller="Home"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="display:block;flex:none;"><path d="M5 12h14M13 6l6 6-6 6"></path></svg> @T["Error.Retry"]</a></div><p class="err-code"><span class="dot"></span>@T["Error.Code"] <b>OIDC_CORRELATION_FAILED</b></p></div></div>
    </main>
</div>
