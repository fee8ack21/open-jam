@{
    ViewData["Title"] = T["RegisterSent.PageTitle"];
    var email = ViewBag.Email as string ?? "";
}

<div class="auth-shell" data-screen="register-sent">
    @await Html.PartialAsync("_BrandPanel", new BrandPanelViewModel {
        Headline = T["Register.BrandHeadline"].Value,
        Sub = T["Register.BrandSub"].Value
    })
    <main class="form-panel">
        <div class="mobile-brand">
            @await Html.PartialAsync("_BrandLockup")
        </div>
        <div class="form-wrap">
            <div class="screen">
                <div class="success-ring cyan">@IconHelper.Render("mail", 40)</div>
                <h2 class="form-title">@T["RegisterSent.Title"]</h2>
                <p class="form-sub">@T["RegisterSent.Sub"]</p>
                <div class="email-chip">@IconHelper.Render("mail", 16) @email</div>
                <p class="form-sub" style="margin-top:18px">@T["RegisterSent.Instruction"]</p>
                <div class="form-body">
                    <a class="btn-pop" asp-action="Login">
                        @IconHelper.Render("check", 18) @T["RegisterSent.VerifyDone"]
                    </a>
                </div>
                <p class="resend" style="text-align:center" data-resend-screen="register-sent" data-resend-email="@email">
                    @T["RegisterSent.NotReceived"] <span class="resend-slot"></span>
                </p>
            </div>
        </div>
    </main>
</div>
