@{
    ViewData["Title"] = "Open Jam · 確認信箱";
    var email = ViewBag.Email as string ?? "";
}

<div class="auth-shell" data-screen="register-sent">
    @await Html.PartialAsync("_BrandPanel", new BrandPanelViewModel {
        Headline = "把作品<br/>變成 <span class=\"hl hl-yellow\">收入</span>。",
        Sub = "加入 12,400+ 創作者，今天就開始在 Open Jam 上架你的數位作品。"
    })
    <main class="form-panel">
        <div class="mobile-brand">
            <span class="brand-mark" style="background:linear-gradient(135deg,var(--c-violet),var(--c-pink))">
                <span style="color:#fff;display:grid;place-items:center">@IconHelper.BrandMark(18)</span>
            </span>
            <span class="brand-name">Open Jam</span>
        </div>
        <div class="form-wrap">
            <div class="screen">
                <div class="success-ring cyan">@IconHelper.Render("mail", 40)</div>
                <h2 class="form-title">確認你的信箱</h2>
                <p class="form-sub">帳號快好了！我們寄了一封確認信到：</p>
                <div class="email-chip">@IconHelper.Render("mail", 16) @email</div>
                <p class="form-sub" style="margin-top:18px">點擊信中的按鈕完成驗證，就能開始上架你的第一件作品。</p>
                <div class="form-body">
                    <a class="btn-pop" asp-action="Login">
                        @IconHelper.Render("check", 18, 2.4) 我驗證好了，去登入
                    </a>
                </div>
                <p class="resend" style="text-align:center" data-resend-screen="register-sent" data-resend-email="@email">
                    沒收到信？<span class="resend-slot"></span>
                </p>
            </div>
        </div>
    </main>
</div>
