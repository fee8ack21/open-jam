@{
    ViewData["Title"] = T["ResetDone.PageTitle"];
}

<div class="auth-shell" data-screen="reset-done">
    @await Html.PartialAsync("_BrandPanel", new BrandPanelViewModel {
        Headline = T["Reset.BrandHeadline"].Value,
        Sub = T["Reset.BrandSub"].Value
    })
    <main class="form-panel">
        <div class="mobile-brand">
            <span class="brand-mark" style="background:linear-gradient(135deg,var(--c-violet),var(--c-pink))">
                <span style="color:#fff;display:grid;place-items:center">@IconHelper.BrandMark(18)</span>
            </span>
            <span class="brand-name">Open Jam</span>
        </div>
        <div class="form-wrap">
            <div class="screen">
                <div class="success-ring">@IconHelper.Render("check", 46, 2.6)</div>
                <h2 class="form-title">@T["ResetDone.Title"]</h2>
                <p class="form-sub">@T["ResetDone.Sub"]</p>
                <div class="form-body">
                    <a class="btn-pop violet" asp-action="Login">
                        @IconHelper.Render("arrowRight", 17) @T["ResetDone.Login"]
                    </a>
                </div>
            </div>
        </div>
    </main>
</div>
