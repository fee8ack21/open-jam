@{
    ViewData["Title"] = T["VerifyDone.PageTitle"];
}

<div class="auth-shell" data-screen="verify-done">
    @await Html.PartialAsync("_BrandPanel", new BrandPanelViewModel {
        Headline = T["VerifyDone.BrandHeadline"].Value,
        Sub = T["VerifyDone.BrandSub"].Value
    })
    <main class="form-panel">
        <div class="mobile-brand">
            <span class="brand-mark" style="background:linear-gradient(135deg,var(--c-violet),var(--c-pink))">
                <span style="color:#fff;display:grid;place-items:center">@IconHelper.BrandMark(18)</span>
            </span>
            <span class="brand-name">Open Jam</span>
        </div>
        <div class="form-wrap">
            <div class="screen">
                <div class="success-ring cyan">@IconHelper.Render("check", 40)</div>
                <h2 class="form-title">@T["VerifyDone.Title"]</h2>
                <p class="form-sub">@T["VerifyDone.Sub"]</p>
                <div class="form-body">
                    <a class="btn-pop violet" asp-action="Login" style="text-decoration:none">
                        @IconHelper.Render("arrowRight", 18) @T["VerifyDone.Login"]
                    </a>
                </div>
            </div>
        </div>
    </main>
</div>
