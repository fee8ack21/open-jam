@{
    ViewData["Title"] = "Open Jam · 信箱驗證成功";
}

<div class="auth-shell font-bricolage" id="auth-shell" data-screen="verify-done">
    @await Html.PartialAsync("_BrandPanel", new BrandPanelModel {
        Headline = "你已<br/><span class=\"hl hl-lime\">驗證成功</span>！",
        Sub = "帳號已開通，開始在 Open Jam 上分享你的創作。"
    })
    <main class="form-panel">
        <div class="mobile-brand">
            <span class="brand-mark" style="background:linear-gradient(135deg,var(--c-violet),var(--c-pink))">
                <span style="color:#fff;display:grid;place-items:center">@IconHelper.BrandMark(18)</span>
            </span>
            <span class="brand-name">Open Jam</span>
        </div>
        <div class="form-wrap">
            <div class="screen">
                <div class="success-ring cyan">@IconHelper.Render("check", 40)</div>
                <h2 class="form-title">信箱驗證成功</h2>
                <p class="form-sub">你的帳號已開通！現在可以登入，開始探索或上架你的第一件作品。</p>
                <div class="form-body">
                    <a class="btn-pop violet" asp-action="Login" style="text-decoration:none">
                        @IconHelper.Render("arrowRight", 18) 前往登入
                    </a>
                </div>
            </div>
        </div>
    </main>
    @await Html.PartialAsync("_TweaksPanel")
    <style id="accent-style"></style>
</div>
