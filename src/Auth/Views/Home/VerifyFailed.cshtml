@{
    ViewData["Title"] = "Open Jam · 驗證連結無效";
}

<div class="auth-shell font-bricolage" id="auth-shell" data-screen="verify-failed">
    @await Html.PartialAsync("_BrandPanel", new BrandPanelModel {
        Headline = "連結<br/><span class=\"hl hl-pink\">已失效</span>。",
        Sub = "驗證連結可能已過期或使用過，請重新申請。"
    })
    <main class="form-panel">
        <div class="mobile-brand">
            <span class="brand-mark" style="background:linear-gradient(135deg,var(--c-violet),var(--c-pink))">
                <span style="color:#fff;display:grid;place-items:center">@IconHelper.BrandMark(18)</span>
            </span>
            <span class="brand-name">Open Jam</span>
        </div>
        <div class="form-wrap">
            <div class="screen">
                <p class="form-eyebrow">@IconHelper.Render("alert", 13) 連結問題</p>
                <h2 class="form-title">驗證連結無效</h2>
                <p class="form-sub">此連結可能已過期（有效期 24 小時）、已使用過，或網址不完整。</p>
                <div class="form-body">
                    <a class="btn-pop violet" asp-action="Register">
                        @IconHelper.Render("arrowRight", 18) 重新註冊取得新連結
                    </a>
                    <a class="btn-ghost" asp-action="Login">返回登入</a>
                </div>
            </div>
        </div>
    </main>
    @await Html.PartialAsync("_TweaksPanel")
    <style id="accent-style"></style>
</div>
