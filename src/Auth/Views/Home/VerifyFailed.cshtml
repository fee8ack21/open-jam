@{
    ViewData["Title"] = T["VerifyFailed.PageTitle"];
}

<div class="auth-shell" data-screen="verify-failed">
    @await Html.PartialAsync("_BrandPanel", new BrandPanelViewModel {
        Headline = T["VerifyFailed.BrandHeadline"].Value,
        Sub = T["VerifyFailed.BrandSub"].Value
    })
    <main class="form-panel">
        <div class="mobile-brand">
            @await Html.PartialAsync("_BrandLockup")
        </div>
        <div class="form-wrap">
            <div class="screen">
                <p class="form-eyebrow">@IconHelper.Render("alert", 13) @T["VerifyFailed.Eyebrow"]</p>
                <h2 class="form-title">@T["VerifyFailed.Title"]</h2>
                <p class="form-sub">@T["VerifyFailed.Sub"]</p>
                <div class="form-body">
                    <a class="btn-pop violet" asp-action="Register">
                        @IconHelper.Render("arrowRight", 18) @T["VerifyFailed.Reregister"]
                    </a>
                    <a class="btn-ghost" asp-action="Login">@T["VerifyFailed.Back"]</a>
                </div>
            </div>
        </div>
    </main>
</div>
