{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "Hydra": {
    "Issuer": "http://localhost:4444/"
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Database=open_jam_storage;Username=postgres;Password=postgres"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "guest"
  },
  "Storage": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "UseSsl": false,
    "Bucket": "open-jam",
    "PublicBaseUrl": "http://localhost:9000/open-jam",
    "UploadUrlExpirySeconds": 3600,
    "DownloadUrlExpirySeconds": 300,
    "UploadTimeoutHours": 24,
    "SoftDeleteRetentionDays": 30
