{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:5175",
      "https://openjam.co",
      "https://workspace.openjam.co",
      "https://*.openjam.co"
    ]
  },
  "Hydra": {
    "Issuer": "http://localhost:4444/"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=open_jam_storage;Username=postgres;Password=postgres"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "guest"
  },
  "Storage": {
    "Provider": "Local",
    "Bucket": "open-jam",
    "PublicBaseUrl": "http://localhost:5171/v1/files/blob",
    "UploadUrlExpirySeconds": 3600,
    "DownloadUrlExpirySeconds": 300,
    "UploadTimeoutHours": 24,
    "SoftDeleteRetentionDays": 30,
    "Local": {
      "RootPath": "Files",
      "BaseUrl": "http://localhost:5171",
      "SigningKey": "dev-local-storage-signing-key-change-me"
    },
    "Gcs": {
      "CredentialsPath": ""
    }
  }
}
